generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model companies {
  id                                      String                                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                    String                                    @unique @db.VarChar(255)
  embedding                               Unsupported("vector")?
  created_at                              DateTime?                                 @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime?                                 @default(now()) @db.Timestamptz(6)
  company_recommendations_for_researchers company_recommendations_for_researchers[]
  researcher_evaluations_by_company       researcher_evaluations_by_company[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model company_recommendations_for_researchers {
  researcher_id         String    @db.Uuid
  company_id            String    @db.Uuid
  company_name          String?   @db.VarChar(255)
  area                  String?   @db.VarChar(255)
  recommendation_reason String?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)
  companies             companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([researcher_id, company_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model researcher_evaluations_by_company {
  researcher_id         String                    @db.Uuid
  company_id            String                    @db.Uuid
  criterion_name        evaluation_criterion_type
  criterion_value       Float                     @db.Real
  recommendation_reason String?
  created_at            DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?                 @default(now()) @db.Timestamptz(6)
  companies             companies                 @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([researcher_id, company_id, criterion_name])
}

model researchers {
  researcher_id String                 @id @db.Uuid
  name          String                 @unique @db.VarChar(255)
  embedding     Unsupported("vector")?
  created_at    DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?              @default(now()) @db.Timestamptz(6)
}

enum evaluation_criterion_type {
  research_alignment
  innovation_potential
  cultural_fit
  relevant_experience
}
